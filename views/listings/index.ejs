<script id="g0m9e8">
let taxSwitch = document.getElementById("flexSwitchCheckDefault");
let prices = document.querySelectorAll(".price");
let taxInfo = document.querySelectorAll(".tax-info");

// restore toggle state
if (localStorage.getItem("taxEnabled") === "true") {
  taxSwitch.checked = true;
}

function updatePrices() {
  prices.forEach((priceEl) => {
    let basePrice = Number(priceEl.getAttribute("data-price"));

    if (taxSwitch.checked) {
      let finalPrice = Math.round(basePrice * 1.18);
      priceEl.innerText = "₹" + finalPrice.toLocaleString("en-IN");
    } else {
      priceEl.innerText = "₹" + basePrice.toLocaleString("en-IN");
    }
  });

  taxInfo.forEach((info) => {
    info.style.display = taxSwitch.checked ? "inline" : "none";
  });
}

updatePrices();

taxSwitch.addEventListener("change", function () {
  localStorage.setItem("taxEnabled", taxSwitch.checked);
  updatePrices();
});
</script>
