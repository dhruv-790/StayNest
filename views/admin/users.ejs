<% layout("/layouts/boilerplate") %>

<style>
.user-card {
  border-radius: 16px;
  transition: 0.3s;
}

.user-card:hover {
  transform: translateY(-5px);
}

.empty-box {
  max-width: 500px;
  border-radius: 16px;
}
</style>

<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">Your Customers</h3>
  </div>

  <% if(users.length === 0) { %>

    <div class="d-flex justify-content-center align-items-center" style="min-height: 50vh;">
      <div class="card empty-box shadow p-4 text-center">
        <i class="fa-regular fa-user mb-3" style="font-size: 50px;"></i>
        <h5>No users yet</h5>
        <p class="text-muted">Users will appear when they book your listings.</p>
        <a href="/listings" class="btn btn-danger">Explore Listings</a>
      </div>
    </div>

  <% } else { %>

    <div class="row g-4">

      <% users.forEach(u => { %>

        <div class="col-md-4">

          <div class="card user-card shadow border-0 p-4">

            <div class="d-flex align-items-center mb-3">

              <div class="me-3">
                <i class="fa-solid fa-user-circle" style="font-size: 40px;"></i>
              </div>

              <div>
                <h5 class="mb-0"><%= u.user.username %></h5>
                <small class="text-muted"><%= u.user.email %></small>
              </div>

            </div>

            <hr>

            <p class="mb-2">
              <i class="fa-solid fa-calendar-check me-2"></i>
              <b>Bookings:</b> <%= u.count %>
            </p>

            <div class="d-flex gap-2 mt-3">

              <a href="/admin/bookings" class="btn btn-sm btn-outline-dark">
                View Bookings
              </a>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

  <% } %>

</div>