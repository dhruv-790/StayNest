<% layout("/layouts/boilerplate") %>

<style>
body {
  background: #f5f7fb;
}

.payment-container {
  height: 85vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.payment-card {
  width: 100%;
  max-width: 420px;
  background: white;
  border-radius: 16px;
  padding: 30px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  text-align: center;
}

.title {
  font-size: 22px;
  font-weight: 700;
  color: #0a66c2;
  margin-bottom: 10px;
}

.subtitle {
  font-size: 14px;
  color: #666;
  margin-bottom: 25px;
}

.price-box {
  background: #f0f6ff;
  border: 1px solid #d6e4ff;
  padding: 12px;
  border-radius: 10px;
  margin-bottom: 25px;
  font-weight: 600;
  color: #0a66c2;
}

.pay-btn {
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 10px;
  background: #0a66c2;
  color: white;
  font-weight: 600;
  cursor: pointer;
  transition: 0.2s;
}

.pay-btn:hover {
  background: #084b91;
}

.note {
  font-size: 12px;
  color: #888;
  margin-top: 12px;
}
</style>

<div class="payment-container">

  <div class="payment-card">

    <div class="title">Complete Payment</div>
    <div class="subtitle">Secure checkout powered by Razorpay</div>

    <div class="price-box">
      Total Amount: ₹<%= total %>
    </div>

    <button class="pay-btn" id="payBtn">
      Pay Now
    </button>

    <div class="note">
      You will be redirected after successful payment
    </div>

  </div>

</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
document.getElementById("payBtn").onclick = async function () {

    const res = await fetch("/bookings/<%= listing._id %>/create-order", {
        method: "POST"
    });

    const data = await res.json();

    const options = {
        key: "<%= process.env.RAZORPAY_KEY_ID %>",
        amount: data.amount * 100,
        currency: "INR",
        order_id: data.order.id,

        handler: async function (response) {

            await fetch("/bookings/<%= listing._id %>/verify-payment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(response)
            });

            window.location.href = "/bookings/success";
        },

        modal: {
            ondismiss: async function () {
                await fetch("/bookings/<%= listing._id %>/cod", {
                    method: "POST"
                });

                window.location.href = "/bookings/cod-success";
            }
        }

    };

    const rzp = new Razorpay(options);
    rzp.open();
};
</script>