<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<style>
.full-page {
  height: 85vh;
}

.booking-card {
  width: 100%;
  max-width: 400px;
  border-radius: 15px;
  border: 1px solid #EDE5DC !important;
  background: #FFFFFF;
}

.booking-card h3 {
  color: #2C1810;
}

.form-label {
  color: #2C1810;
  font-weight: 500;
}

.form-control {
  border: 1px solid #EDE5DC;
  color: #2C1810;
  background-color: #FFFFFF;
}

.form-control:focus {
  border-color: #C1440E;
  box-shadow: 0 0 0 3px rgba(193, 68, 14, 0.12);
  outline: none;
}

.btn-book {
  background-color: #C1440E;    /* was #ff385c */
  color: white;
  font-weight: 600;
  border-radius: 10px;
  border: none;
}

.btn-book:hover {
  background-color: #A33A0C;    /* was #e03150 */
  color: white;
}

.note-text {
  font-size: 12px;
  color: #C1440E;               /* was red */
  text-align: center;
  margin-top: 8px;
}

/* flatpickr terracotta override */
.flatpickr-day.selected,
.flatpickr-day.selected:hover {
  background: #C1440E !important;
  border-color: #C1440E !important;
}

.flatpickr-day:hover {
  background: #FDDCC8 !important;
  color: #2C1810 !important;
}

.flatpickr-months .flatpickr-month,
.flatpickr-weekdays {
  background: #FBF5EF !important;
  color: #2C1810 !important;
}

.flatpickr-current-month,
.flatpickr-monthDropdown-months,
.flatpickr-weekday {
  color: #2C1810 !important;
}

.flatpickr-day.today {
  border-color: #C1440E !important;
  color: #C1440E !important;
}
</style>


<div class="container full-page d-flex justify-content-center align-items-center">

  <div class="card booking-card shadow p-4">

    <h3 class="text-center mb-4">Book Your Stay</h3>

  <form action="/bookings/<%= listing._id %>/payment" method="GET">

      
      <div class="mb-3">
        <label class="form-label">Check In</label>
        <input 
          type="date"
          id="checkIn"
          name="checkIn"
          class="form-control w-100"
          placeholder="Select date"
          required
        >
      </div>

      
      <div class="mb-3">
        <label class="form-label">Check Out</label>
        <input 
          type="date"
          id="checkOut"
          name="checkOut"
          class="form-control w-100"
          placeholder="Select date"
          required
        >
      </div>

      <div class="mb-3">
        <label class="form-label">Guests</label>
        <input 
          type="number"
          name="guests"
          class="form-control w-100"
          min="1"
          required
        >
      </div>

      <button type="submit" class="btn btn-book w-100">
        Confirm Booking
      </button>

      <div class="note-text">
        CLICK ONCE TO CONFIRM BOOKING
      </div>

    </form>

  </div>

</div>


<script>

const checkInPicker = flatpickr("#checkIn", {
  minDate: "today",
  dateFormat: "Y-m-d",
  onChange: function(selectedDates) {
    checkOutPicker.set("minDate", selectedDates[0]);
  }
});


const checkOutPicker = flatpickr("#checkOut", {
  minDate: "today",
  dateFormat: "Y-m-d"
});
</script>