<% layout("/layouts/boilerplate") %>

<style>
.full-page {
  min-height: 80vh;
}

.confirm-card {
  max-width: 500px;
  width: 100%;
  border-radius: 18px;
  background: #fff;
}

.success-icon {
  font-size: 65px;
  color: #22c55e;
}

.btn-primary-custom {
  background-color: #ff385c;
  border: none;
  border-radius: 10px;
  font-weight: 600;
}

.btn-primary-custom:hover {
  background-color: #e03150;
}

.btn-outline-custom {
  border-radius: 10px;
}

.info-text {
  font-size: 15px;
  margin-bottom: 6px;
}
</style>

<div class="container d-flex justify-content-center align-items-center full-page">

  <div class="card confirm-card shadow-lg p-4 text-center">

    <div class="mb-3">
      <i class="fa-solid fa-circle-check success-icon"></i>
    </div>

    <h2 class="text-success fw-bold">Booking Confirmed!</h2>
    <p class="text-muted mb-3">Your reservation is successfully completed.</p>

    <hr>

    <h4 class="fw-semibold mb-3"><%= booking.listing.title %></h4>

    <p class="info-text"><b>Guest:</b> <%= booking.user.username %></p>
    <p class="info-text"><b>Check-in:</b> <%= booking.checkIn.toDateString() %></p>
    <p class="info-text"><b>Check-out:</b> <%= booking.checkOut.toDateString() %></p>
    <p class="info-text"><b>Guests:</b> <%= booking.guests %></p>

    <hr>

    <div class="d-flex gap-2 justify-content-center mt-3">
      <a href="/bookings" class="btn btn-primary-custom px-3">
        View My Bookings
      </a>

      <a href="/listings" class="btn btn-outline-secondary btn-outline-custom px-3">
        Explore
      </a>
      <a href="/bookings/<%= booking._id %>/ticket" class="btn btn-success">
    Download Ticket
     </a>
    </div>

  </div>

</div>